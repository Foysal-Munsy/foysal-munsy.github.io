---
import { Icon } from "astro-icon/components";

// A single list row with a logo, a heading with a right-aligned meta (period),
// and supporting text. Used for work, education, and CP entries.
//
// The logo slot supports three modes:
//   - `logo`  : an image path under public/ (company/school logo)
//   - `icon`  : a Lucide icon name (e.g. "code") for CP entries
//   - neither : a monogram derived from the title's first letter
interface Props {
    title: string;
    meta?: string;
    subtitle?: string;
    logo?: string | null;
    icon?: string;
}
const { title, meta, subtitle, logo, icon } = Astro.props;

const base = import.meta.env.BASE_URL;
const home = base.endsWith("/") ? base : `${base}/`;
const logoSrc = logo ? `${home}${logo.replace(/^\//, "")}` : null;
const monogram = title.trim().charAt(0).toUpperCase();
---

<div class="row">
    <div class="logo" aria-hidden="true">
        {logoSrc ? (
            <img src={logoSrc} alt="" loading="lazy" />
        ) : icon ? (
            <Icon name={`lucide:${icon}`} />
        ) : (
            <span class="monogram">{monogram}</span>
        )}
    </div>
    <div class="body">
        <div class="head">
            <span class="who">{title}</span>
            {meta && <span class="when">{meta}</span>}
        </div>
        {subtitle && <p class="role">{subtitle}</p>}
        <slot />
    </div>
</div>

<style>
    .row {
        display: flex;
        gap: 1rem;
        padding: 1rem 0;
        border-bottom: 1px solid var(--border);
    }

    .row:last-child {
        border-bottom: none;
    }

    .logo {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        background: var(--surface);
        border: 1px solid var(--border);
        display: grid;
        place-items: center;
        overflow: hidden;
        flex-shrink: 0;
    }

    .logo img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 6px;
    }


    .logo :global(svg) {
        width: 1.25rem;
        height: 1.25rem;
        color: var(--text);
    }

    .monogram {
        font-weight: 700;
        font-size: 0.85rem;
        font-family: theme("fontFamily.mono");
        color: var(--text);
    }

    .body {
        flex: 1;
        min-width: 0;
    }

    .head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: baseline;
    }

    .who {
        font-weight: 650;
        font-size: 0.98rem;
    }

    .when {
        color: var(--text-muted);
        font-size: 0.78rem;
        white-space: nowrap;
        font-family: theme("fontFamily.mono");
    }

    .role {
        margin: 0.15rem 0 0;
        color: var(--text-muted);
        font-size: 0.88rem;
        font-weight: 500;
    }

    .body :global(ul) {
        margin: 0.5rem 0 0;
        padding-left: 1.1rem;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .body :global(li) {
        margin: 0.25rem 0;
    }
</style>
