---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";

const base = import.meta.env.BASE_URL;
const home = base.endsWith("/") ? base : `${base}/`;

const posts = (await getCollection("blog"))
    .filter((e) => !e.data.draft)
    .sort(
        (a, b) =>
            b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
    );

const fmt = (d: Date) =>
    d.toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
    });
---

<BaseLayout
    title="Blog — Foysal Munsy"
    description="Writing on software engineering and systems."
>
    <PageHeader
        title="Blog"
        intro="Notes on software engineering, systems, and things I learn along the way."
        backHref={home}
        backLabel="Home"
    />

    {posts.length === 0 ? (
        <p class="empty">No posts yet. Check back soon.</p>
    ) : (
        <div class="list">
            {posts.map((post) => (
                <a class="post" href={`${home}blog/${post.slug}`}>
                    <div class="head">
                        <h3>{post.data.title}</h3>
                        <span class="date">{fmt(post.data.publishDate)}</span>
                    </div>
                    <p class="summary">{post.data.summary}</p>
                </a>
            ))}
        </div>
    )}
</BaseLayout>

<style>
    .list {
        display: flex;
        flex-direction: column;
    }

    .post {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        padding: 1.25rem 0;
        border-bottom: 1px solid var(--border);
        color: var(--text);
    }

    .post:last-child {
        border-bottom: none;
    }

    .post:hover {
        text-decoration: none;
    }

    .post:hover h3 {
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
    }

    .post h3 {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 700;
    }

    .date {
        font-family: theme("fontFamily.mono");
        font-size: 0.72rem;
        color: var(--text-muted);
        white-space: nowrap;
    }

    .summary {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.92rem;
    }

    .empty {
        color: var(--text-muted);
    }
</style>
