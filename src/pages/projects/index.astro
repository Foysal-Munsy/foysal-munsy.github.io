---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ProjectRow from "../../components/ProjectRow.astro";
import Pagination from "../../components/Pagination.astro";
import {
  PROJECTS_PER_PAGE,
  projectCardProps,
  sortedProjects,
} from "../../data/projectList";

const base = import.meta.env.BASE_URL;
const home = base.endsWith("/") ? base : `${base}/`;
const listBase = `${home}projects`.replace(/\/$/, "");

const projects = sortedProjects(await getCollection("projects"));

const totalPages = Math.max(1, Math.ceil(projects.length / PROJECTS_PER_PAGE));
const pageItems = projects.slice(0, PROJECTS_PER_PAGE);
---

<BaseLayout
  title="Projects – Foysal Munsy"
  description="Engineering projects and case studies."
>
  <PageHeader
    title="Projects"
    intro="Selected engineering work. Entries with a full case study open a detailed write-up; the rest link out to their source."
    backHref={home}
    backLabel="Home"
  />

  {
    pageItems.length === 0 ? (
      <p class="empty">No projects published yet.</p>
    ) : (
      <div class="list">
        {pageItems.map((p) => (
          <ProjectRow {...projectCardProps(p, home)} />
        ))}
      </div>
    )
  }

  <Pagination currentPage={1} totalPages={totalPages} base={listBase} />
</BaseLayout>

<style>
  .list {
    display: flex;
    flex-direction: column;
  }

  .empty {
    color: var(--text-muted);
  }
</style>
