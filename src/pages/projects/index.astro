---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import TextListItem from "../../components/TextListItem.astro";

const base = import.meta.env.BASE_URL;
const home = base.endsWith("/") ? base : `${base}/`;

const projects = (await getCollection("projects"))
    .filter((e) => !e.data.draft)
    .sort((a, b) => {
        if (a.data.order !== b.data.order) return a.data.order - b.data.order;
        return a.data.title.localeCompare(b.data.title);
    });
---

<BaseLayout
    title="Projects — Foysal Munsy"
    description="Engineering projects and case studies."
>
    <PageHeader
        title="Projects"
        intro="Selected engineering work. Entries with a full case study open a detailed write-up; the rest link out to their source."
        backHref={home}
        backLabel="Home"
    />

    {projects.length === 0 ? (
        <p class="empty">No projects published yet.</p>
    ) : (
        <div class="list">
            {projects.map((p) => {
                // A project with a case-study body opens the internal detail
                // page; otherwise it links out to its repo/live URL.
                const hasCaseStudy = p.body.trim().length > 0;
                const external = !hasCaseStudy && !!(p.data.repo || p.data.liveUrl);
                const href = hasCaseStudy
                    ? `${home}projects/${p.slug}`
                    : p.data.repo ?? p.data.liveUrl ?? `${home}projects/${p.slug}`;
                return (
                    <TextListItem
                        title={p.data.title}
                        summary={p.data.summary}
                        meta={p.data.timeframe}
                        href={href}
                        external={external}
                    />
                );
            })}
        </div>
    )}
</BaseLayout>

<style>
    .list {
        display: flex;
        flex-direction: column;
    }

    .empty {
        color: var(--text-muted);
    }
</style>
