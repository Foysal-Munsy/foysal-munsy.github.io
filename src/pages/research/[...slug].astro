---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TechBadge from "../../components/TechBadge.astro";

// Pre-render a detail page only for research entries that have a body. Entries
// that are just a citation with a DOI/report link stay on the list page.
export async function getStaticPaths() {
    const entries = await getCollection("research");
    return entries
        .filter((entry) => entry.body.trim().length > 0)
        .map((entry) => ({
            params: { slug: entry.slug },
            props: { entry },
        }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;

const base = import.meta.env.BASE_URL;
const home = base.endsWith("/") ? base : `${base}/`;
---

<BaseLayout title={`${d.title} — Research`} description={d.summary}>
    <a href={`${home}research`} class="back">← All research</a>

    <header class="header fade-up">
        <h1>{d.title}</h1>
        <p class="summary">{d.summary}</p>
        <p class="meta">{d.venue} · {d.year}</p>

        {d.tags.length > 0 && (
            <div class="tags">
                {d.tags.map((t) => <TechBadge label={t} />)}
            </div>
        )}

        {(d.doi || d.link || d.fullReport) && (
            <div class="links">
                {d.link && (
                    <a href={d.link} target="_blank" rel="noopener noreferrer">Report ↗</a>
                )}
                {d.fullReport && (
                    <a href={d.fullReport} target="_blank" rel="noopener noreferrer">Full report ↗</a>
                )}
                {d.doi && (
                    <a href={d.doi} target="_blank" rel="noopener noreferrer">DOI ↗</a>
                )}
            </div>
        )}
    </header>

    <article class="prose fade-up">
        <Content />
    </article>
</BaseLayout>

<style>
    .back {
        display: inline-block;
        margin-bottom: 1.5rem;
        font-family: theme("fontFamily.mono");
        font-size: 0.82rem;
        color: var(--text-muted);
    }

    .back:hover {
        color: var(--text);
        text-decoration: none;
    }

    .header {
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
    }

    .header h1 {
        margin: 0 0 0.75rem;
        font-size: 2.1rem;
        font-weight: 800;
        line-height: 1.15;
        letter-spacing: -0.03em;
    }

    .summary {
        margin: 0 0 0.75rem;
        font-size: 1.1rem;
        color: var(--text-muted);
    }

    .meta {
        margin: 0 0 1.25rem;
        font-family: theme("fontFamily.mono");
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 1.25rem;
    }

    .links {
        display: flex;
        gap: 1rem;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .links a {
        text-decoration: underline;
        text-underline-offset: 3px;
    }
</style>
