---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import TextListItem from "../../components/TextListItem.astro";

const base = import.meta.env.BASE_URL;
const home = base.endsWith("/") ? base : `${base}/`;

const entries = (await getCollection("research"))
    .filter((e) => !e.data.draft)
    .sort((a, b) => {
        if (a.data.order !== b.data.order) return a.data.order - b.data.order;
        return a.data.title.localeCompare(b.data.title);
    });
---

<BaseLayout
    title="Research — Foysal Munsy"
    description="Research and publications in computer vision."
>
    <PageHeader
        title="Research"
        intro="Publications and academic work, mostly in computer vision and object detection under adverse conditions."
        backHref={home}
        backLabel="Home"
    />

    {entries.length === 0 ? (
        <p class="empty">No research published yet.</p>
    ) : (
        <div class="list">
            {entries.map((r) => {
                // A write-up (body) opens an internal detail page; a
                // citation-only entry links out to its report/DOI.
                const hasWriteup = r.body.trim().length > 0;
                const external =
                    !hasWriteup &&
                    !!(r.data.link || r.data.fullReport || r.data.doi);
                const href = hasWriteup
                    ? `${home}research/${r.slug}`
                    : r.data.link ??
                      r.data.fullReport ??
                      r.data.doi ??
                      `${home}research/${r.slug}`;
                return (
                    <TextListItem
                        title={r.data.title}
                        summary={r.data.summary}
                        meta={`${r.data.venue} · ${r.data.year}`}
                        href={href}
                        external={external}
                    />
                );
            })}
        </div>
    )}
</BaseLayout>

<style>
    .list {
        display: flex;
        flex-direction: column;
    }

    .empty {
        color: var(--text-muted);
    }
</style>
